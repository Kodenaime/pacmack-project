{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "types": ["node"]
  },
  "include": [
    "controller/**/*",
    "middleware/**/*",
    "models/**/*",
    "routes/**/*",
    "services/**/*",
    "types/**/*",
    "server.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
